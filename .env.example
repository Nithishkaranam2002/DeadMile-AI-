# =============================================================================
# DeadMile AI — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# NEVER commit .env — it contains secrets
# =============================================================================

# --- General ---
COMPOSE_PROJECT_NAME=deadmile-ai
ENVIRONMENT=development
LOG_LEVEL=INFO

# Production: set ENVIRONMENT=production, API_GATEWAY_KEY, NEXT_PUBLIC_APP_MODE=production
# API_GATEWAY_KEY=
# NEXT_PUBLIC_APP_MODE=development

# --- LLM Configuration (OpenAI primary) ---
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
# LLM_API_BASE=  # Leave empty for OpenAI; set for Groq/Featherless/Ollama-compatible APIs
LITELLM_LOG=INFO

# Alternative LLM providers (uncomment one):
# Groq (free): LLM_MODEL=groq/llama-3.1-70b-versatile  GROQ_API_KEY=gsk_xxx
# Ollama (local): LLM_MODEL=ollama/llama3.1  LLM_API_BASE=http://host.docker.internal:11434
# Featherless: LLM_MODEL=openai/meta-llama/Llama-3.1-70B-Instruct  LLM_API_BASE=https://api.featherless.ai/v1  OPENAI_API_KEY=your_featherless_key

# --- Web Search ---
TAVILY_API_KEY=tvly-your-key-here

# --- Maps (set one) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here
# NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key-here

# --- PostgreSQL (PostGIS + TimescaleDB) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=deadmile
POSTGRES_USER=deadmile
POSTGRES_PASSWORD=deadmile_secret_change_me
DATABASE_URL=postgresql+asyncpg://deadmile:deadmile_secret_change_me@postgres:5432/deadmile

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=loads

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=deadmile_minio
MINIO_ROOT_PASSWORD=deadmile_minio_secret_change_me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=broker-sheets
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=deadmile_minio
MINIO_SECRET_KEY=deadmile_minio_secret_change_me

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_LOADS=raw-loads
KAFKA_GROUP_LOAD_PROCESSOR=load-processor-group
ZOOKEEPER_CONNECT=zookeeper:2181

# --- Temporal ---
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=load-chain-queue
TEMPORAL_ADDRESS=temporal:7233

# --- Langfuse (optional) ---
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Service URLs (internal Docker network) ---
API_GATEWAY_URL=http://api-gateway:8000
AGENT_CORE_URL=http://agent-core:8001
LOAD_INGESTION_URL=http://load-ingestion:8002
LOAD_PROCESSOR_URL=http://load-processor:8003
PROFITABILITY_ENGINE_URL=http://profitability-engine:8004
MARKET_INTELLIGENCE_URL=http://market-intelligence:8005
FRONTEND_URL=http://frontend:3000

# --- Service Ports (host mappings) ---
API_GATEWAY_PORT=8000
AGENT_CORE_PORT=8001
LOAD_INGESTION_PORT=8002
LOAD_PROCESSOR_PORT=8003
PROFITABILITY_ENGINE_PORT=8004
MARKET_INTELLIGENCE_PORT=8005
FRONTEND_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# --- Geocoding ---
GEOCODING_PROVIDER=nominatim
NOMINATIM_USER_AGENT=deadmile-ai/1.0

# --- Profitability Defaults (wired to shared/cost_settings.py) ---
DEFAULT_FUEL_PRICE=3.90
DEFAULT_DRIVER_PAY_PER_MILE=0.55
DEFAULT_INSURANCE_PER_MILE=0.12
DEFAULT_MAINTENANCE_PER_MILE=0.15
DEFAULT_FUEL_MPG=6.5
DEFAULT_TOLL_RATE_PER_MILE=0.08
DEFAULT_MAX_DEADHEAD_MILES=250

# --- Frontend (public, exposed to browser — must be set at Docker BUILD time) ---
NEXT_PUBLIC_API_URL=http://localhost:8010
NEXT_PUBLIC_AGENT_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=DeadMile AI
NEXT_PUBLIC_APP_MODE=development

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=deadmile_grafana_change_me
OTEL_EXPORTER_OTLP_ENDPOINT=http://temporal:4317
OTEL_SERVICE_NAME=deadmile-ai

# --- Data Paths ---
DATA_TEXT_PATH=/data/text
DATA_PDF_PATH=/data/pdf
